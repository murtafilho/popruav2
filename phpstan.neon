includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    paths:
        - app
        - database
        - routes

    # Rule level (0 is the loosest and 9 is the strictest)
    level: 5

    ignoreErrors:
        - '#Call to an undefined method Spatie\\Image\\Drivers\\ImageDriver::performOnCollections#'

    excludePaths:
        - ./*/*/FileToIgnore.php