{
    "mcpServers": {
        "laravel-boost": {
            "command": "php",
            "args": [
                "artisan",
                "boost:mcp"
            ]
        },
        "context7": {
            "command": "npx",
            "args": ["-y", "@upstash/context7-mcp"]
        },
        "leaflet": {
            "command": "node",
            "args": ["tools/leaflet-mcp-server/build/index.js"]
        },
        "openstreetmap": {
            "command": "/root/.local/bin/uvx",
            "args": ["osm-mcp-server"]
        }
    }
}
